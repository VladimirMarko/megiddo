{
  "name": "megiddo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "tsx scripts/check-frontend-contract-boundaries.mts && biome check --write",
    "dev": "tsx scripts/run-local-dev.mts",
    "dev:api": "pnpm --filter @megiddo/api dev",
    "dev:frontend": "pnpm --filter @megiddo/frontend dev",
    "dev:identity": "pnpm --filter @megiddo/identity dev",
    "dev:local": "tsx scripts/run-local-dev.mts",
    "dev:reset": "tsx scripts/reset-local-dev-data.mts",
    "dev:todo": "pnpm --filter @megiddo/todo dev",
    "dev:turbo": "turbo dev",
    "sandcastle": "tsx .sandcastle/main.mts",
    "sandcastle:build-image": "sandcastle docker build-image --image-name sandcastle:megiddo",
    "telemetry:viewer": "tsx scripts/run-telemetry-viewer.mts",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:integration:local": "node --import tsx --test tests/integration/local-development-workflow.test.ts"
  },
  "dependencies": {
    "@megiddo/api": "workspace:*",
    "@megiddo/contracts": "workspace:*",
    "@megiddo/identity": "workspace:*",
    "@megiddo/platform": "workspace:*",
    "@megiddo/todo": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@biomejs/biome": "2.5.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@total-typescript/tsconfig": "catalog:",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.9.0"
}
