[
  {
    "variable": "API_PORT",
    "owner": "Local Dev Script",
    "surface": "script",
    "allowedValues": "TCP port string",
    "defaultValue": "3000",
    "description": "Port injected into API Gateway as PORT by pnpm dev."
  },
  {
    "variable": "FRONTEND_PORT",
    "owner": "Local Dev Script",
    "surface": "script",
    "allowedValues": "TCP port string",
    "defaultValue": "5173",
    "description": "Port passed to Vite and injected into frontend as PORT by pnpm dev."
  },
  {
    "variable": "IDENTITY_PORT",
    "owner": "Local Dev Script",
    "surface": "script",
    "allowedValues": "TCP port string",
    "defaultValue": "3002",
    "description": "Port injected into Identity as PORT by pnpm dev."
  },
  {
    "variable": "MEGIDDO_LOCAL_DATA_DIR",
    "owner": "Local Dev Script",
    "surface": "script",
    "allowedValues": "non-empty filesystem path",
    "defaultValue": ".data/local-dev under workspace root",
    "description": "Base directory used by local dev and reset scripts for embedded service data."
  },
  {
    "variable": "TODO_PORT",
    "owner": "Local Dev Script",
    "surface": "script",
    "allowedValues": "TCP port string",
    "defaultValue": "3001",
    "description": "Port injected into Todo as PORT by pnpm dev."
  },
  {
    "variable": "OTEL_GUI_BIN",
    "owner": "Telemetry Viewer Script",
    "surface": "script",
    "allowedValues": "executable path or command name",
    "defaultValue": "otel-gui",
    "description": "Telemetry viewer binary invoked by pnpm telemetry:viewer."
  },
  {
    "variable": "OTEL_GUI_PORT",
    "owner": "Telemetry Viewer Script",
    "surface": "script",
    "allowedValues": "TCP port string",
    "defaultValue": "4318 unless PORT is set",
    "description": "Viewer ingest port fallback used by pnpm telemetry:viewer."
  },
  {
    "variable": "PORT",
    "owner": "Telemetry Viewer Script",
    "surface": "script",
    "allowedValues": "TCP port string",
    "defaultValue": "4318 for viewer when OTEL_GUI_PORT is unset",
    "description": "Telemetry viewer ingest port; takes precedence over OTEL_GUI_PORT."
  }
]
